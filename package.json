    "test:all": "npm run test && npm run test:api && npm run test:e2e",
    "test:report": "node scripts/test-report.cjs",
    "test:report:api": "node scripts/test-report.cjs --api-only",
    "test:db:reset": "node scripts/test-db-reset.cjs"
  },
