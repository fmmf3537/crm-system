{
  "name": "crm-system",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:seed": "node scripts/seed-from-json.cjs",
    "db:seed:demo": "node scripts/seed-demo.cjs",
    "db:seed:demo:reset": "node scripts/seed-demo.cjs --reset",
    "test": "vitest run --coverage",
